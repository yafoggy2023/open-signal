# Секреты
bot_token.txt
bot_token.txt.txt
bot_token*
config.local.php

# Загрузки пользователей
uploads/*
# Но демо-файлы (генерируемые gen_demo_files.php) включаем в репозиторий,
# чтобы fresh install сразу показывал работу с прикреплёнными файлами.
!uploads/АПО-2026-1000*/

# Бэкапы
backups/
*.backup
*.bak

# Дампы БД (могут содержать персональные данные)
# По умолчанию игнорируем все .sql, но явно разрешаем:
#   schema.sql — только структура (источник истины для fresh install)
#   db.sql     — полный дамп (структура + данные) для синхронизации между машинами
# ВНИМАНИЕ: когда в БД появятся реальные пользовательские данные —
# уберите исключение db.sql и синхронизируйте иначе (файловая шара / бэкап-сервер).
*.sql
!schema.sql
!db.sql
!demo_data.sql

# Логи
*.log
logs/

# IDE / ОС
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Временные файлы
*.tmp
*.swp
*~

# Claude Code настройки (локальные, с путями dev-машины)
.claude/
